KEEP_LOGS = 50


def _prune_old_logs():
    """Delete session log files beyond the most recent KEEP_LOGS."""
    if not LOGS_DIR.exists():
        return
    logs = sorted(LOGS_DIR.glob("session_*.log"))
    for old in logs[:-KEEP_LOGS]:
